{
  "manifest_version": 3,
  "name": "sidekick",
  "version": "1.0",
  "minimum_chrome_version": "114",
  "permissions": ["activeTab", "scripting", "tabs", "sidePanel"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Sidekick"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
