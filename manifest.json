{
  "manifest_version": 3,
  "name": "sidekick",
  "version": "1.0",
  "permissions": ["sidePanel", "activeTab", "scripting", "http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
